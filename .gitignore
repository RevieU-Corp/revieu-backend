# Documentation policy: Ignore all markdown files except README.md and docs/
*.md
!README.md
!docs/**/*.md

# Temporary and worktree files
*.txt
.worktrees/

# Secrets policy: ignore plaintext secrets, keep sealed secrets tracked
apps/**/configs/*secrets*.yaml
!apps/**/configs/sealed-secrets*.yaml

# OS generated files: Ignore all .DS_Store files across the entire project
.DS_Store
**/.DS_Store